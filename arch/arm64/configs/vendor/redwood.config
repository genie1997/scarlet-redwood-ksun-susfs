# Redwood build config
CONFIG_MACH_XIAOMI_REDWOOD=y

# Charger
CONFIG_AI_RSOC=y
CONFIG_BQ_CLOUD_AUTHENTICATION=y
CONFIG_BQ_FG_1S=y
CONFIG_BQ_FUEL_GAUGE=y
CONFIG_BQ2597X_BATTERY_CHARGER=y

# Fingerprint
CONFIG_GOODIX_FINGERPRINT=y
CONFIG_XIAOMI_FINGERPRINT=y

# Disable mmc driver
# CONFIG_MMC is not set

# Disable fsa4480 (Redwood doesn't support usb audio)
# CONFIG_QCOM_FSA4480_I2C is not set

# KernelSU
CONFIG_KSU=y
CONFIG_KSU_MANUAL_HOOK=y

# SUSFS
CONFIG_KSU_SUSFS=y
CONFIG_KSU_SUSFS_SUS_PATH=y
CONFIG_KSU_SUSFS_SUS_MOUNT=y
CONFIG_KSU_SUSFS_SUS_KSTAT=y
CONFIG_KSU_SUSFS_TRY_UMOUNT=n
CONFIG_KSU_SUSFS_SPOOF_UNAME=y
CONFIG_KSU_SUSFS_ENABLE_LOG=y
CONFIG_KSU_SUSFS_HIDE_KSU_SUSFS_SYMBOLS=y
CONFIG_KSU_SUSFS_SPOOF_CMDLINE_OR_BOOTCONFIG=y
CONFIG_KSU_SUSFS_OPEN_REDIRECT=y
CONFIG_KSU_SUSFS_SUS_MAP=y

# --- Persistent crash logging (bootloop post-mortem) ---
# PSTORE/RAM are already =y in xiaomi-qgki_defconfig and the ramoops region
# exists in yupik.dtsi (4MB @ 0xb0000000, record-size 2MB). Re-stated here for
# clarity. A kernel *panic/oops* is captured into dmesg-ramoops via kmsg_dump
# (PANIC_ON_OOPS is already y). What was NOT captured before was a pure *hang*
# (e.g. the SELinux rwlock self-deadlock): a hang triggers a watchdog/warm reset
# without kmsg_dump. The lockup/hung-task detectors below convert such a hang
# into a panic so it, too, lands in the existing ramoops record.
# NOTE: the ramoops node has no console-size and lives in the vendor_boot DTB,
# which the kernel-only AnyKernel3 flash does NOT update — so console-ramoops
# stays unavailable; only dmesg-ramoops (panic records) is usable here.
CONFIG_PSTORE=y
CONFIG_PSTORE_CONSOLE=y
CONFIG_PSTORE_PMSG=y
CONFIG_PSTORE_RAM=y
CONFIG_PANIC_ON_OOPS=y
CONFIG_DEBUG_KERNEL=y
CONFIG_SOFTLOCKUP_DETECTOR=y
CONFIG_BOOTPARAM_SOFTLOCKUP_PANIC=y
CONFIG_DETECT_HUNG_TASK=y
CONFIG_BOOTPARAM_HUNG_TASK_PANIC=y
